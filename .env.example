# Cross-site link base URLs (production values)
# Used by each app to link to the others. Override in .env.local for local dev.
NEXT_PUBLIC_VAGUE_FREQUENCY_LABS_URL=https://v.f.labs.com
NEXT_PUBLIC_PAYDAY_RECORDS_URL=https://payday-records.com
NEXT_PUBLIC_CELEBRATE_AGENCY_URL=https://celebrate-agency.com
NEXT_PUBLIC_JUNTARO_URL=

# Supabase (content CMS — admin + 4 sites)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# On-demand revalidate shared secret (admin + 4 sites)
REVALIDATE_SECRET=
